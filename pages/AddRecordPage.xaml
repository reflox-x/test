<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="pawledger.pages.AddRecordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Add Record"
    BackgroundColor="#F4F4F8"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Grid ColumnDefinitions="Auto,*">
                <Button
                    Text="‹"
                    BackgroundColor="Transparent"
                    TextColor="#355070"
                    FontSize="24"
                    Clicked="OnBackClicked" />

                <Label
                    Grid.Column="1"
                    Text="Add Record"
                    HorizontalOptions="Center"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="#355070" />
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button
                    x:Name="ExpenseButton"
                    Text="Expense"
                    BackgroundColor="#F7CACA"
                    TextColor="#C96969"
                    CornerRadius="16"
                    Clicked="OnExpenseClicked" />

                <Button
                    x:Name="IncomeButton"
                    Grid.Column="1"
                    Text="Income"
                    BackgroundColor="#EAF1EF"
                    TextColor="#8AA4AF"
                    CornerRadius="16"
                    Clicked="OnIncomeClicked" />
            </Grid>

            <Frame CornerRadius="18" BackgroundColor="White" Padding="16" HasShadow="False">
                <Entry
                    x:Name="AmountEntry"
                    Text="55"
                    FontSize="28"
                    Keyboard="Numeric"
                    TextColor="#243B53" />
            </Frame>

            <Button
                Text="Save Record"
                HeightRequest="54"
                CornerRadius="18"
                BackgroundColor="#F3DC8C"
                TextColor="#355070"
                FontAttributes="Bold"
                Clicked="OnSaveClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>