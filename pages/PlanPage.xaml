<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="pawledger.pages.PlanPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Plan"
    BackgroundColor="#F4F4F8">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="Plan"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="#355070" />

            <Frame CornerRadius="20" BackgroundColor="White" Padding="16" HasShadow="False">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Saved 5,000" FontSize="22" FontAttributes="Bold" TextColor="#243B53" />
                    <Label Text="25%" FontSize="18" TextColor="#243B53" />
                    <ProgressBar Progress="0.25" ProgressColor="#4FA9CC" BackgroundColor="#D7EAF2" />
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="20" BackgroundColor="White" Padding="16" HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="¥10,000 - 2026/06/01" FontSize="16" />
                    <Label Text="¥15,000 - 2026/07/01" FontSize="16" />
                    <Label Text="¥20,000 - 2026/08/01" FontSize="16" />
                </VerticalStackLayout>
            </Frame>

            <Button
                Text="+ Add to plan"
                HeightRequest="54"
                CornerRadius="18"
                BackgroundColor="#F3DC8C"
                TextColor="#355070"
                FontAttributes="Bold"
                Clicked="OnAddPlanClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>